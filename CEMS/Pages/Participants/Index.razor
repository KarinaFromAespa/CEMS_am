@page "/admin/participants"
@rendermode InteractiveServer
@inject AppDbContext Db
@inject IParticipantService ParticipantSvc

<div class="d-flex justify-content-between align-items-center mb-4">
    <h3 class="fw-bold">Participants</h3>
    <button class="btn btn-success" @onclick="OpenAddForm">
        <i class="bi bi-person-plus me-1"></i> Add Participant
    </button>
</div>

<div class="position-fixed bottom-0 end-0 p-3" style="z-index: 1050">
    <div class="toast align-items-center text-white bg-dark border-0 shadow-lg fade @(showToast ? "show" : "hide")" role="alert" style="border-radius: 12px;">
        <div class="d-flex p-2">
            <div class="toast-body">
                <i class="bi bi-check-circle-fill text-success me-2"></i> @toastMessage
            </div>
            <button type="button" class="btn-close btn-close-white m-auto me-2" @onclick="() => showToast = false"></button>
        </div>
    </div>
</div>

@if (showDeleteConfirmation)
{
    <div class="modal-backdrop fade show" style="z-index: 1040;"></div>
    <div class="modal fade show d-block" tabindex="-1" style="top: 20%; z-index: 1050;">
        <div class="modal-dialog modal-dialog-centered" style="max-width: 400px;">
            <div class="modal-content border-0 shadow-lg p-3" style="border-radius: 16px;">
                <div class="modal-body text-center">
                    <div class="text-danger mb-3">
                        <i class="bi bi-exclamation-triangle" style="font-size: 3rem;"></i>
                    </div>
                    <h5 class="fw-bold mb-2">Confirm Delete</h5>
                    <p class="text-muted small px-3">
                        Are you sure you want to permanently delete <strong class="text-dark">"@participantToDelete?.Name"</strong>? This action cannot be undone.
                    </p>
                </div>
                <div class="d-flex gap-2 px-3 pb-2">
                    <button type="button" class="btn btn-light w-50 fw-semibold" style="border-radius: 8px;" @onclick="CancelDelete">Cancel</button>
                    <button type="button" class="btn btn-danger w-50 fw-semibold" style="border-radius: 8px;" @onclick="ConfirmDelete">Delete</button>
                </div>
            </div>
        </div>
    </div>
}

@if (showForm)
{
    <div class="card border-0 shadow-sm mb-4">
        <div class="card-body">
            <h5>@(editingId == null ? "New Participant" : "Edit Participant")</h5>
            <div class="row g-3">
                <div class="col-md-4">
                    <label class="form-label">Full Name</label>
                    <input class="form-control" @bind="form.Name" />
                </div>
                <div class="col-md-4">
                    <label class="form-label">Email</label>
                    <input type="email" class="form-control" @bind="form.Email" />
                </div>
                <div class="col-md-4">
                    <label class="form-label">Phone</label>
                    <input type="tel" class="form-control" @bind="form.Phone" placeholder="+447700123456" />
                </div>
            </div>

            @if (editingId == null)
            {
                <div class="row g-3 mt-2">
                    <div class="col-md-6">
                        <label class="form-label">Password</label>
                        <input type="password" class="form-control" @bind="newPassword" />
                        <div class="form-text">Min 8 chars, uppercase, lowercase, number & special char.</div>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Confirm Password</label>
                        <input type="password" class="form-control" @bind="confirmPassword" />
                    </div>
                </div>
            }

            @if (!string.IsNullOrEmpty(formError))
            {
                <div class="alert alert-danger mt-3 py-2">@formError</div>
            }
            <div class="mt-3 d-flex gap-2">
                <button class="btn btn-primary" @onclick="SaveParticipant">Save</button>
                <button class="btn btn-outline-secondary" @onclick="CancelForm">Cancel</button>
            </div>
        </div>
    </div>
}

@if (resetPasswordId.HasValue)
{
    <div class="card border-warning shadow-sm mb-4">
        <div class="card-body">
            <h5>Reset Password for <strong>@resetPasswordName</strong></h5>
            <div class="row g-3">
                <div class="col-md-6">
                    <label class="form-label">New Password</label>
                    <input type="password" class="form-control" @bind="resetNewPassword" />
                    <div class="form-text">Min 8 chars, uppercase, lowercase, number & special char.</div>
                </div>
                <div class="col-md-6">
                    <label class="form-label">Confirm Password</label>
                    <input type="password" class="form-control" @bind="resetConfirmPassword" />
                </div>
            </div>
            @if (!string.IsNullOrEmpty(resetError))
            {
                <div class="alert alert-danger mt-2 py-2">@resetError</div>
            }
            @if (!string.IsNullOrEmpty(resetSuccess))
            {
                <div class="alert alert-success mt-2 py-2">@resetSuccess</div>
            }
            <div class="mt-3 d-flex gap-2">
                <button class="btn btn-warning" @onclick="DoResetPassword">Reset Password</button>
                <button class="btn btn-outline-secondary" @onclick="CancelReset">Cancel</button>
            </div>
        </div>
    </div>
}

<div class="card border-0 shadow-sm">
    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
            <thead class="table-light">
                <tr><th>Name</th><th>Email</th><th>Phone</th><th>Reg.</th><th class="text-end">Actions</th></tr>
            </thead>
            <tbody>
                @foreach (var p in participants)
                {
                    <tr>
                        <td>@p.Name</td>
                        <td>@p.Email</td>
                        <td>@p.Phone</td>
                        <td><span class="badge bg-secondary">@p.Registrations.Count</span></td>
                        <td class="text-end">
                            <button class="btn btn-sm btn-outline-warning me-1" @onclick="() => StartEdit(p)">Edit</button>
                            <button class="btn btn-sm btn-outline-info me-1" @onclick="() => StartResetPassword(p)">Reset PW</button>
                            <button class="btn btn-sm btn-outline-danger" @onclick="() => RequestDelete(p)">Delete</button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@code {
    [Inject] private SessionService Session { get; set; } = default!;
    [Inject] private NavigationManager NavigationManager { get; set; } = default!;
    private List<Participant> participants = new();
    private Participant form = new();
    private int? editingId;
    private bool showForm;
    private string formError = "";
    private int? resetPasswordId;
    private string resetPasswordName = "";
    private string resetNewPassword = "";
    private string resetConfirmPassword = "";
    private string resetError = "";
    private string resetSuccess = "";
    private string newPassword = "";
    private string confirmPassword = "";

    // Popup States
    private bool showToast;
    private string toastMessage = "";
    private bool showDeleteConfirmation;
    private Participant? participantToDelete;

    protected override async Task OnInitializedAsync()
    {
        if (!Session.IsAdmin)
        {
            NavigationManager.NavigateTo("/admin/login");
            return;
        }
        participants = await Db.Participants
            .Include(p => p.Registrations)
            .ToListAsync();
    }

    private void OpenAddForm()
    {
        showForm = true;
        editingId = null;
        form = new();
        newPassword = "";
        confirmPassword = "";
        formError = "";
        resetPasswordId = null;
    }

    private void StartEdit(Participant p)
    {
        editingId = p.ParticipantId;
        form = new Participant { Name = p.Name, Email = p.Email, Phone = p.Phone };
        showForm = true;
        resetPasswordId = null;
        resetError = "";
        resetSuccess = "";
    }

    private void StartResetPassword(Participant p)
    {
        resetPasswordId = p.ParticipantId;
        resetPasswordName = p.Name;
        resetNewPassword = "";
        resetConfirmPassword = "";
        resetError = "";
        resetSuccess = "";
        showForm = false;
    }

    private void CancelForm()
    {
        showForm = false;
        editingId = null;
        form = new();
        newPassword = "";
        confirmPassword = "";
        formError = "";
    }

    private void CancelReset()
    {
        resetPasswordId = null;
        resetNewPassword = "";
        resetConfirmPassword = "";
        resetError = "";
        resetSuccess = "";
    }

    private async Task ShowToastNotification(string msg)
    {
        toastMessage = msg;
        showToast = true;
        StateHasChanged();

        await Task.Delay(3000);
        showToast = false;
        StateHasChanged();
    }

    private void RequestDelete(Participant p)
    {
        participantToDelete = p;
        showDeleteConfirmation = true;
    }

    private void CancelDelete()
    {
        showDeleteConfirmation = false;
        participantToDelete = null;
    }

    private async Task ConfirmDelete()
    {
        if (participantToDelete != null)
        {
            var p = await Db.Participants.FindAsync(participantToDelete.ParticipantId);
            if (p != null)
            {
                Db.Participants.Remove(p);
                await Db.SaveChangesAsync();
            }

            string name = participantToDelete.Name;
            showDeleteConfirmation = false;
            participantToDelete = null;

            participants = await Db.Participants.Include(p => p.Registrations).ToListAsync();
            _ = ShowToastNotification($"Participant \"{name}\" was successfully deleted.");
        }
    }

    private bool IsValidEmail(string email)
    {
        try
        {
            var addr = new System.Net.Mail.MailAddress(email);
            var domain = addr.Host;
            return addr.Address == email && domain.Contains('.');
        }
        catch
        {
            return false;
        }
    }

    private bool IsValidPassword(string password, out string pwError)
    {
        pwError = "";
        if (password.Length < 8) { pwError = "Password must be at least 8 characters."; return false; }
        if (!password.Any(char.IsUpper)) { pwError = "Password must contain at least one uppercase letter."; return false; }
        if (!password.Any(char.IsLower)) { pwError = "Password must contain at least one lowercase letter."; return false; }
        if (!password.Any(char.IsDigit)) { pwError = "Password must contain at least one number."; return false; }
        if (!password.Any(c => !char.IsLetterOrDigit(c))) { pwError = "Password must contain at least one special character."; return false; }
        return true;
    }

    private bool IsValidPhone(string ph, out string phError)
    {
        phError = "";
        var digits = ph.Replace(" ", "").Replace("-", "");
        if (!digits.StartsWith("+"))
        {
            phError = "Phone number must start with a country code (e.g. +44).";
            return false;
        }
        var afterPlus = digits.Substring(1);
        if (!afterPlus.All(char.IsDigit))
        {
            phError = "Phone number may only contain digits after the country code prefix.";
            return false;
        }
        if (afterPlus.Length < 11 || afterPlus.Length > 13)
        {
            phError = "Phone number must have a country code plus 10 digits (e.g. +447700123456).";
            return false;
        }
        return true;
    }

    private async Task SaveParticipant()
    {
        formError = "";
        if (string.IsNullOrWhiteSpace(form.Name)) { formError = "Name is required."; return; }
        if (string.IsNullOrWhiteSpace(form.Email)) { formError = "Email is required."; return; }
        if (!IsValidEmail(form.Email)) { formError = "Enter a valid email address (e.g. user@example.com)."; return; }
        if (!string.IsNullOrWhiteSpace(form.Phone) && !IsValidPhone(form.Phone.Trim(), out var phError)) { formError = phError; return; }

        if (editingId == null)
        {
            if (string.IsNullOrWhiteSpace(newPassword)) { formError = "Password is required."; return; }
            if (!IsValidPassword(newPassword, out var pwError)) { formError = pwError; return; }
            if (newPassword != confirmPassword) { formError = "Passwords do not match."; return; }
        }

        try
        {
            string logMsg = "";
            if (editingId.HasValue)
            {
                var existing = await Db.Participants.FindAsync(editingId.Value);
                if (existing != null)
                {
                    existing.Name = form.Name;
                    existing.Email = form.Email;
                    existing.Phone = form.Phone;
                }
                logMsg = $"Participant \"{form.Name}\" was updated.";
            }
            else
            {
                bool emailExists = await Db.Participants.AnyAsync(p => p.Email == form.Email);
                if (emailExists) { formError = "A participant with this email already exists."; return; }

                form.PasswordHash = BCrypt.Net.BCrypt.HashPassword(newPassword);
                form.CreatedAt = DateTime.UtcNow;
                Db.Participants.Add(form);
                logMsg = $"Participant \"{form.Name}\" was successfully created.";
            }

            await Db.SaveChangesAsync();
            participants = await Db.Participants.Include(p => p.Registrations).ToListAsync();
            CancelForm();
            _ = ShowToastNotification(logMsg);
        }
        catch (Exception ex)
        {
            formError = $"Error: {ex.Message}";
        }
    }

    private async Task DoResetPassword()
    {
        resetError = "";
        resetSuccess = "";

        if (string.IsNullOrWhiteSpace(resetNewPassword)) { resetError = "Password is required."; return; }
        if (!IsValidPassword(resetNewPassword, out var pwError)) { resetError = pwError; return; }
        if (resetNewPassword != resetConfirmPassword) { resetError = "Passwords do not match."; return; }

        var ok = await ParticipantSvc.ResetPasswordAsync(resetPasswordId!.Value, resetNewPassword);
        if (ok)
        {
            resetSuccess = $"Password for {resetPasswordName} has been reset successfully.";
            _ = ShowToastNotification($"Password reset for {resetPasswordName}.");
            resetNewPassword = "";
            resetConfirmPassword = "";
        }
        else
        {
            resetError = "Failed to reset password. Participant not found.";
        }
    }
}