@page "/admin/venues"
@rendermode InteractiveServer
@inject AppDbContext Db

<div class="d-flex justify-content-between align-items-center mb-4">
    <h3 class="fw-bold">Venues</h3>
    <button class="btn btn-success" @onclick="() => showForm = true">
        <i class="bi bi-geo-alt-plus me-1"></i> Add Venue
    </button>
</div>

<div class="position-fixed bottom-0 end-0 p-3" style="z-index: 1050">
    <div class="toast align-items-center text-white bg-dark border-0 shadow-lg fade @(showToast ? "show" : "hide")" role="alert" style="border-radius: 12px;">
        <div class="d-flex p-2">
            <div class="toast-body">
                <i class="bi bi-check-circle-fill text-success me-2"></i> @toastMessage
            </div>
            <button type="button" class="btn-close btn-close-white m-auto me-2" @onclick="() => showToast = false"></button>
        </div>
    </div>
</div>

@if (showDeleteConfirmation)
{
    <div class="modal-backdrop fade show" style="z-index: 1040;"></div>
    <div class="modal fade show d-block" tabindex="-1" style="top: 20%; z-index: 1050;">
        <div class="modal-dialog modal-dialog-centered" style="max-width: 400px;">
            <div class="modal-content border-0 shadow-lg p-3" style="border-radius: 16px;">
                <div class="modal-body text-center">
                    <div class="text-danger mb-3">
                        <i class="bi bi-exclamation-triangle" style="font-size: 3rem;"></i>
                    </div>
                    <h5 class="fw-bold mb-2">Confirm Delete</h5>
                    <p class="text-muted small px-3">
                        Are you sure you want to permanently delete <strong class="text-dark">"@venueToDelete?.Name"</strong>? This action cannot be undone.
                    </p>
                </div>
                <div class="d-flex gap-2 px-3 pb-2">
                    <button type="button" class="btn btn-light w-50 fw-semibold" style="border-radius: 8px;" @onclick="CancelDelete">Cancel</button>
                    <button type="button" class="btn btn-danger w-50 fw-semibold" style="border-radius: 8px;" @onclick="ConfirmDelete">Delete</button>
                </div>
            </div>
        </div>
    </div>
}

@if (showForm)
{
    <div class="card border-0 shadow-sm mb-4">
        <div class="card-body">
            <h5>@(editingId == null ? "New Venue" : "Edit Venue")</h5>
            <div class="row g-3">
                <div class="col-md-4">
                    <label class="form-label">Name</label>
                    <input class="form-control" @bind="form.Name" placeholder="Community Hall" />
                </div>
                <div class="col-md-4">
                    <label class="form-label">Address</label>
                    <input class="form-control" @bind="form.Address" />
                </div>
                <div class="col-md-4">
                    <label class="form-label">Capacity</label>
                    <input type="number" class="form-control" @bind="form.Capacity" />
                </div>
            </div>
            @if (!string.IsNullOrEmpty(formError))
            {
                <div class="alert alert-danger mt-3 py-2">@formError</div>
            }
            <div class="mt-3 d-flex gap-2">
                <button class="btn btn-primary" @onclick="SaveVenue">Save</button>
                <button class="btn btn-outline-secondary" @onclick="CancelForm">Cancel</button>
            </div>
        </div>
    </div>
}

<div class="card border-0 shadow-sm">
    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
            <thead class="table-light">
                <tr><th>Name</th><th>Address</th><th>Capacity</th><th class="text-end">Actions</th></tr>
            </thead>
            <tbody>
                @foreach (var v in venues)
                {
                    <tr>
                        <td>@v.Name</td>
                        <td>@v.Address</td>
                        <td>@v.Capacity</td>
                        <td class="text-end">
                            <button class="btn btn-sm btn-outline-warning me-1" @onclick="() => StartEdit(v)">Edit</button>
                            <button class="btn btn-sm btn-outline-danger" @onclick="() => RequestDelete(v)">Delete</button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@code {
    [Inject] private SessionService Session { get; set; } = default!;
    [Inject] private NavigationManager NavigationManager { get; set; } = default!;
    private List<Venue> venues = new();
    private Venue form = new();
    private int? editingId;
    private bool showForm;
    private string formError = "";

    // Popup Interface Properties
    private bool showToast;
    private string toastMessage = "";
    private bool showDeleteConfirmation;
    private Venue? venueToDelete;

    protected override async Task OnInitializedAsync()
    {
        if (!Session.IsAdmin)
        {
            NavigationManager.NavigateTo("/admin/login");
            return;
        }
        venues = await Db.Venues.ToListAsync();
    }

    private void StartEdit(Venue v)
    {
        editingId = v.VenueId;
        form = new Venue { Name = v.Name, Address = v.Address, Capacity = v.Capacity };
        showForm = true;
    }

    private void CancelForm()
    {
        showForm = false;
        editingId = null;
        form = new();
        formError = "";
    }

    private async Task ShowToastNotification(string msg)
    {
        toastMessage = msg;
        showToast = true;
        StateHasChanged();

        await Task.Delay(3000);
        showToast = false;
        StateHasChanged();
    }

    private void RequestDelete(Venue v)
    {
        venueToDelete = v;
        showDeleteConfirmation = true;
    }

    private void CancelDelete()
    {
        showDeleteConfirmation = false;
        venueToDelete = null;
    }

    private async Task ConfirmDelete()
    {
        if (venueToDelete != null)
        {
            var v = await Db.Venues.FindAsync(venueToDelete.VenueId);
            if (v != null)
            {
                Db.Venues.Remove(v);
                await Db.SaveChangesAsync();
            }

            string name = venueToDelete.Name;
            showDeleteConfirmation = false;
            venueToDelete = null;

            venues = await Db.Venues.ToListAsync();
            _ = ShowToastNotification($"Venue \"{name}\" was successfully deleted.");
        }
    }

    private async Task SaveVenue()
    {
        formError = "";
        if (string.IsNullOrWhiteSpace(form.Name)) { formError = "Name is required."; return; }
        if (form.Capacity <= 0) { formError = "Capacity must be greater than 0."; return; }

        try
        {
            string statusMsg = "";
            if (editingId.HasValue)
            {
                var existing = await Db.Venues.FindAsync(editingId.Value);
                if (existing != null)
                {
                    existing.Name = form.Name;
                    existing.Address = form.Address;
                    existing.Capacity = form.Capacity;
                }
                statusMsg = $"Venue \"{form.Name}\" was updated.";
            }
            else
            {
                Db.Venues.Add(form);
                statusMsg = $"Venue \"{form.Name}\" was created successfully.";
            }

            await Db.SaveChangesAsync();
            venues = await Db.Venues.ToListAsync();
            CancelForm();
            _ = ShowToastNotification(statusMsg);
        }
        catch (Exception ex)
        {
            formError = $"Error: {ex.Message}";
        }
    }
}