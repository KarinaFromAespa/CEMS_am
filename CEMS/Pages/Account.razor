@page "/account"
@rendermode InteractiveServer
@inject AppDbContext Db
@inject SessionService Session
@inject NavigationManager Nav

@if (!Session.IsLoggedIn)
{
    <div class="text-center py-5 text-muted">Redirecting...</div>
}
else if (participant == null)
{
    <div class="text-center py-5 text-muted">Loading...</div>
}
else
{
    <div class="row g-4">
        <div class="col-lg-4">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center">
                    <h5 class="mb-0"><i class="bi bi-person-circle me-2"></i>My Profile</h5>
                    @if (!isEditing)
                    {
                        <button @onclick="ToggleEdit" class="btn btn-sm btn-light text-primary fw-semibold">
                            <i class="bi bi-pencil-square me-1"></i>Edit
                        </button>
                    }
                    else
                    {
                        <div class="btn-group gap-1">
                            <button @onclick="SaveChanges" class="btn btn-sm btn-success fw-semibold">
                                <i class="bi bi-check-lg"></i> Save
                            </button>
                            <button @onclick="ToggleEdit" class="btn btn-sm btn-light text-danger fw-semibold">
                                Cancel
                            </button>
                        </div>
                    }
                </div>
                <div class="card-body">
                    <div class="d-flex flex-column gap-3">
                        @if (!isEditing)
                        {
                            <div class="row g-0 align-items-center">
                                <div class="col-5 fw-bold text-secondary">Name</div>
                                <div class="col-7 text-dark fw-semibold">@participant.Name</div>
                            </div>
                            <div class="row g-0 align-items-center">
                                <div class="col-5 fw-bold text-secondary">Email</div>
                                <div class="col-7 text-dark text-break">@participant.Email</div>
                            </div>
                            <div class="row g-0 align-items-center">
                                <div class="col-5 fw-bold text-secondary">Phone</div>
                                <div class="col-7 text-dark">@participant.Phone</div>
                            </div>
                        }
                        else
                        {
                            <div class="row g-0 align-items-center">
                                <div class="col-5 fw-bold text-secondary">Name</div>
                                <div class="col-7">
                                    <input type="text" class="form-control form-control-sm" @bind="participant.Name" />
                                </div>
                            </div>
                            <div class="row g-0 align-items-center">
                                <div class="col-5 fw-bold text-secondary">Email</div>
                                <div class="col-7">
                                    <input type="email" class="form-control form-control-sm" @bind="participant.Email" />
                                </div>
                            </div>
                            <div class="row g-0 align-items-center">
                                <div class="col-5 fw-bold text-secondary">Phone</div>
                                <div class="col-7">
                                    <input type="text" class="form-control form-control-sm" @bind="participant.Phone" />
                                </div>
                            </div>
                        }
                        <div class="row g-0 align-items-center">
                            <div class="col-5 fw-bold text-secondary">Member since</div>
                            <div class="col-7 text-dark">@participant.CreatedAt.ToString("dd MMM yyyy")</div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-lg-8">
            <div class="card border-0 shadow-sm">
                <div class="card-header bg-white d-flex justify-content-between align-items-center">
                    <h5 class="mb-0 fw-bold">My Registrations</h5>
                    <a href="/register" class="btn btn-sm btn-primary"><i class="bi bi-plus-circle me-1"></i> Register</a>
                </div>
                <div class="card-body p-0">
                    @if (!registrations.Any())
                    {
                        <p class="text-muted p-3 mb-0">You haven't registered for any events yet.</p>
                    }
                    else
                    {
                        <div class="table-responsive">
                            <table class="table table-hover align-middle mb-0">
                                <thead class="table-light">
                                    <tr><th>Event</th><th>Date</th><th>Venue</th><th>Status</th><th></th></tr>
                                </thead>
                                <tbody>
                                    @foreach (var reg in registrations)
                                    {
                                        <tr>
                                            <td>@reg.Event?.Name</td>
                                            <td>@reg.Event?.Date.ToString("dd MMM yyyy")</td>
                                            <td>@reg.Event?.Venue?.Name</td>
                                            <td><span class="badge bg-@StatusColor(reg.Status)">@reg.Status</span></td>
                                            <td class="text-end">
                                                @if (reg.Status != "Cancelled")
                                                {
                                                    <button class="btn btn-sm btn-outline-danger"
                                                            @onclick="() => PromptCancel(reg.RegistrationId, reg.Event?.Name)">
                                                        Cancel
                                                    </button>
                                                }
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
}

@if (showCancelConfirm)
{
    <div class="modal-backdrop fade show" style="z-index:1040;"></div>
    <div class="modal fade show d-block" style="z-index:1050;" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content border-0 shadow">
                <div class="modal-header bg-danger text-white">
                    <h5 class="modal-title">Cancel Registration</h5>
                </div>
                <div class="modal-body">
                    <p>Are you sure you want to cancel your registration for <strong>@cancelEventName</strong>?</p>
                    <p class="text-muted small mb-0">This action cannot be undone.</p>
                </div>
                <div class="modal-footer">
                    <button class="btn btn-outline-secondary" @onclick="() => showCancelConfirm = false">Keep Registration</button>
                    <button class="btn btn-danger" @onclick="ConfirmCancel">Yes, Cancel</button>
                </div>
            </div>
        </div>
    </div>
}


@code {
    private Participant? participant;
    private List<Registration> registrations = new();

    private bool showCancelConfirm = false;
    private int pendingCancelId = 0;
    private string cancelEventName = "";

    // Track editing state
    private bool isEditing = false;

    protected override async Task OnInitializedAsync()
    {
        if (!Session.IsLoggedIn)
        {
            Nav.NavigateTo("/login");
            return;
        }

        participant = await Db.Participants.FindAsync(Session.CurrentParticipantId);

        registrations = await Db.Registrations
            .Include(r => r.Event).ThenInclude(e => e!.Venue)
            .Where(r => r.ParticipantId == Session.CurrentParticipantId)
            .OrderByDescending(r => r.RegistrationDate)
            .ToListAsync();
    }

    private void ToggleEdit()
    {
        isEditing = !isEditing;
    }

    private async Task SaveChanges()
    {
        if (participant != null)
        {
            Db.Participants.Update(participant);
            await Db.SaveChangesAsync();
            isEditing = false;
        }
    }

    private void PromptCancel(int id, string? eventName)
    {
        pendingCancelId = id;
        cancelEventName = eventName ?? "this event";
        showCancelConfirm = true;
    }

    private async Task ConfirmCancel()
    {
        showCancelConfirm = false;
        var reg = await Db.Registrations.FindAsync(pendingCancelId);
        if (reg != null && reg.ParticipantId == Session.CurrentParticipantId)
        {
            bool wasConfirmed = reg.Status == "Confirmed";
            int eventId = reg.EventId;

            reg.Status = "Cancelled";
            await Db.SaveChangesAsync();
            Db.ChangeTracker.Clear();

            if (wasConfirmed)
            {
                var nextWaitlisted = await Db.Registrations
                    .Include(r => r.Participant)
                    .Where(r => r.EventId == eventId && r.Status == "Waitlisted")
                    .OrderBy(r => r.RegistrationDate)
                    .FirstOrDefaultAsync();

                if (nextWaitlisted != null)
                {
                    nextWaitlisted.Status = "Confirmed";
                    await Db.SaveChangesAsync();
                    Db.ChangeTracker.Clear();
                }
            }

            registrations = await Db.Registrations
                .Include(r => r.Event).ThenInclude(e => e!.Venue)
                .Where(r => r.ParticipantId == Session.CurrentParticipantId)
                .OrderByDescending(r => r.RegistrationDate)
                .ToListAsync();
        }
    }

    private void Logout()
    {
        Session.LogoutParticipant();
        Nav.NavigateTo("/");
    }

    private string StatusColor(string status) => status switch
    {
        "Confirmed" => "success",
        "Cancelled" => "danger",
        "Waitlisted" => "warning",
        "Pending" => "secondary",
        _ => "secondary"
    };
}